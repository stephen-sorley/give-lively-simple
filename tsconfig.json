{
  "compilerOptions": {
    /* Base Options */
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022", "DOM"],

    /* Strictness */
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "verbatimModuleSyntax": true,

    /* Bundler Compatibility */
    "moduleDetection": "force",
    "resolveJsonModule": true,

    /* Build/Bundle Output */
    "declaration": true,
    "isolatedDeclarations": true,
    "incremental": true,
    "rootDir": "/",
    "outDir": "dist"
  },
  "include": ["**/*"]
}